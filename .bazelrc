# warning level
build --copt=-Wall
build --copt=-Werror

# Use color diagnostics
build --copt=-fdiagnostics-color

# Automatically apply the build:linux / build:macos / build:windows configs
# below based on the host OS.
build --enable_platform_specific_config

# Work around a broken CommandLineTools libc++ include path on some macOS setups
# by pointing at the C++ headers that ship inside the active SDK. Scoped to
# macOS so it never leaks into Linux/Windows builds.
build:macos --cxxopt=-isystem/Library/Developer/CommandLineTools/SDKs/MacOSX.sdk/usr/include/c++/v1
build:macos --host_cxxopt=-isystem/Library/Developer/CommandLineTools/SDKs/MacOSX.sdk/usr/include/c++/v1

# Always assert
build --copt=-UNDEBUG

# Add C++14 compiler flags (minimum required by modern googletest).
build --cxxopt=-std=c++14
build --host_cxxopt=-std=c++14

# code coverage
coverage --copt=-fno-inline
coverage --copt=-fno-inline-small-functions
coverage --copt=-fno-default-inline

# remote cache, see here https://docs.bazel.build/versions/2.0.0/remote-caching.html
build --experimental_guard_against_concurrent_changes

test --test_output=errors
